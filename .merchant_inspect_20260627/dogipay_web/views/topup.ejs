<%- include('partials/head') %>
<% const activePage = 'topup' %>
<div class="app-layout">
  <%- include('partials/sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div>
        <div class="breadcrumb"><span>Dashboards</span> / <span class="bc-active">Isi Saldo</span></div>
        <h1 class="page-title">Isi Saldo Customer</h1>
      </div>
      <div class="topbar-right">
        <span class="badge-merchant"><i class="fa-solid fa-circle" style="color:#4ade80;font-size:8px"></i> Merchant Aktif</span>
        <div class="avatar-wrap">
          <div class="avatar"><%= merchant.name.charAt(0).toUpperCase() %></div>
          <div>
            <p class="avatar-name"><%= merchant.name %></p>
            <p class="avatar-role">Merchant</p>
          </div>
        </div>
      </div>
    </div>

    <% if (error && error.length > 0) { %>
      <div class="alert alert-error"><i class="fa-solid fa-circle-exclamation"></i> <%= error[0] %></div>
    <% } %>

    <div class="topup-layout">
      <!-- Step 1: Cari Customer -->
      <div class="card">
        <div class="card-header">
          <h3><i class="fa-solid fa-magnifying-glass"></i> Cari Customer</h3>
        </div>
        <form action="/topup/cek" method="POST" class="search-form">
          <div class="form-group">
            <label>No. Telepon atau QR Code Customer</label>
            <div class="input-row">
              <input type="text" name="phone_or_qr" placeholder="08xxxxxxxxxx atau scan QR" required />
              <button type="submit" class="btn-primary"><i class="fa-solid fa-search"></i> Cek</button>
            </div>
          </div>
        </form>

        <% if (customer) { %>
          <div class="customer-found">
            <div class="customer-avatar-lg"><%= customer.name.charAt(0) %></div>
            <div class="customer-detail">
              <p class="customer-name-lg"><%= customer.name %></p>
              <p class="customer-phone-lg"><i class="fa-solid fa-phone"></i> <%= customer.phone %></p>
              <p class="customer-saldo">Saldo saat ini: <strong>Rp <%= Number(customer.saldo).toLocaleString('id-ID') %></strong></p>
            </div>
            <span class="badge badge-success"><i class="fa-solid fa-circle-check"></i> Ditemukan</span>
          </div>
        <% } %>
      </div>

      <!-- Step 2: Pilih Nominal (hanya muncul jika customer ditemukan) -->
      <% if (customer) { %>
      <div class="card">
        <div class="card-header">
          <h3><i class="fa-solid fa-wallet"></i> Pilih Nominal Top-up</h3>
        </div>
        <form action="/topup/proses" method="POST" id="topupForm">
          <input type="hidden" name="user_id" value="<%= customer.id %>" />
          <input type="hidden" name="amount" id="amountInput" />

          <div class="nominal-grid">
            <% [10000, 25000, 50000, 100000, 200000, 500000].forEach(nom => { %>
              <div class="nominal-card" onclick="selectNominal(<%= nom %>, this)">
                <p>Rp <%= nom.toLocaleString('id-ID') %></p>
              </div>
            <% }) %>
          </div>

          <div class="form-group" style="margin-top:16px">
            <label>Atau masukkan nominal lain</label>
            <input type="number" id="customAmount" placeholder="Rp 0" min="1000" onchange="setCustom(this.value)" />
          </div>

          <div class="form-group">
            <label>Catatan (opsional)</label>
            <input type="text" name="note" placeholder="Contoh: Top-up via kasir" />
          </div>

          <div class="summary-box" id="summaryBox" style="display:none">
            <div class="summary-row"><span>Penerima</span><span><%= customer.name %></span></div>
            <div class="summary-row"><span>Saldo sebelum</span><span>Rp <%= Number(customer.saldo).toLocaleString('id-ID') %></span></div>
            <div class="summary-row"><span>Nominal top-up</span><span id="summaryNominal">-</span></div>
            <div class="summary-row summary-total"><span>Saldo setelah</span><span id="summaryAfter">-</span></div>
          </div>

          <button type="submit" class="btn-primary btn-full" id="btnProses" disabled>
            <i class="fa-solid fa-bolt"></i> Proses Top-up
          </button>
        </form>
      </div>
      <% } %>
    </div>
  </div>
</div>

<script>
  const saldoBefore = <%= customer ? customer.saldo : 0 %>;
  let selectedAmount = 0;

  function selectNominal(amount, el) {
    document.querySelectorAll('.nominal-card').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');
    document.getElementById('customAmount').value = '';
    setAmount(amount);
  }

  function setCustom(val) {
    document.querySelectorAll('.nominal-card').forEach(c => c.classList.remove('selected'));
    setAmount(parseFloat(val) || 0);
  }

  function setAmount(amount) {
    selectedAmount = amount;
    document.getElementById('amountInput').value = amount;
    const after = saldoBefore + amount;
    document.getElementById('summaryNominal').textContent = 'Rp ' + amount.toLocaleString('id-ID');
    document.getElementById('summaryAfter').textContent = 'Rp ' + after.toLocaleString('id-ID');
    document.getElementById('summaryBox').style.display = amount > 0 ? 'block' : 'none';
    document.getElementById('btnProses').disabled = amount <= 0;
  }
</script>
</body>
</html>
