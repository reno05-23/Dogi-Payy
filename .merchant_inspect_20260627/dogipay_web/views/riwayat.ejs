<%- include('partials/head') %>
<% const activePage = 'riwayat' %>
<div class="app-layout">
  <%- include('partials/sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div>
        <div class="breadcrumb"><span>Dashboards</span> / <span class="bc-active">Riwayat</span></div>
        <h1 class="page-title">Riwayat Transaksi</h1>
      </div>
      <div class="topbar-right">
        <span class="badge-merchant"><i class="fa-solid fa-circle" style="color:#4ade80;font-size:8px"></i> Merchant Aktif</span>
        <div class="avatar-wrap">
          <div class="avatar"><%= merchant.name.charAt(0).toUpperCase() %></div>
          <div>
            <p class="avatar-name"><%= merchant.name %></p>
            <p class="avatar-role">Merchant</p>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h3><i class="fa-solid fa-clock-rotate-left"></i> Total <%= total %> Transaksi</h3>
        <form action="/riwayat" method="GET" class="search-inline">
          <input type="text" name="search" placeholder="Cari nama atau no. HP..." value="<%= search %>" />
          <button type="submit" class="btn-primary"><i class="fa-solid fa-search"></i></button>
          <% if (search) { %>
            <a href="/riwayat" class="btn-reset"><i class="fa-solid fa-xmark"></i></a>
          <% } %>
        </form>
      </div>

      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>#</th>
              <th>Customer</th>
              <th>No. HP</th>
              <th>Nominal</th>
              <th>Saldo Sebelum</th>
              <th>Saldo Sesudah</th>
              <th>Catatan</th>
              <th>Waktu</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (transactions.length === 0) { %>
              <tr><td colspan="9" class="text-center text-muted" style="padding:32px">
                <i class="fa-solid fa-receipt" style="font-size:24px;margin-bottom:8px;display:block"></i>
                Belum ada transaksi
              </td></tr>
            <% } else { %>
              <% transactions.forEach((tx, i) => { %>
                <tr>
                  <td class="text-muted"><%= (currentPage - 1) * 15 + i + 1 %></td>
                  <td>
                    <div class="customer-cell">
                      <div class="mini-avatar"><%= tx.customer_name.charAt(0) %></div>
                      <%= tx.customer_name %>
                    </div>
                  </td>
                  <td class="text-muted"><%= tx.customer_phone %></td>
                  <td class="amount-green">+Rp <%= Number(tx.amount).toLocaleString('id-ID') %></td>
                  <td class="text-muted">Rp <%= Number(tx.saldo_before).toLocaleString('id-ID') %></td>
                  <td class="text-muted">Rp <%= Number(tx.saldo_after).toLocaleString('id-ID') %></td>
                  <td class="text-muted"><%= tx.note || '-' %></td>
                  <td class="text-muted">
                    <%= new Date(tx.created_at).toLocaleDateString('id-ID') %>
                    <span style="display:block;font-size:11px">
                      <%= new Date(tx.created_at).toLocaleTimeString('id-ID', {hour:'2-digit',minute:'2-digit'}) %>
                    </span>
                  </td>
                  <td>
                    <span class="badge <%= tx.status === 'success' ? 'badge-success' : 'badge-failed' %>">
                      <%= tx.status === 'success' ? 'Berhasil' : 'Gagal' %>
                    </span>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (currentPage > 1) { %>
            <a href="/riwayat?page=<%= currentPage - 1 %>&search=<%= search %>" class="page-btn">
              <i class="fa-solid fa-chevron-left"></i>
            </a>
          <% } %>
          <% for (let p = 1; p <= totalPages; p++) { %>
            <a href="/riwayat?page=<%= p %>&search=<%= search %>"
               class="page-btn <%= p === currentPage ? 'active' : '' %>"><%= p %></a>
          <% } %>
          <% if (currentPage < totalPages) { %>
            <a href="/riwayat?page=<%= currentPage + 1 %>&search=<%= search %>" class="page-btn">
              <i class="fa-solid fa-chevron-right"></i>
            </a>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>
</body>
</html>