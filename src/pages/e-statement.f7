<template>
    <div class="page" data-name="e-statement">
        <div class="navbar no-shadow no-hairline" style="height: 70px;">
            <div class="navbar-bg warna_dasar_sistem"></div>
            <div class="navbar-inner warna_dasar_sistem">
                <div class="left">
                    <a href="#" class="link back text-color-white icon-only">
                        <i class="icon f7-icons font20">arrow_left</i>
                    </a>
                </div>
                <div class="title text-color-white font16 font-weight-bold">e-Statement</div>
                <div class="right"></div>
            </div>
        </div>

        <div class="page-content">

            <div class="card no-shadow radius15">
                <div class="card-content card-content-padding">
                    <div id="es-filter-wrap"></div>
                </div>
            </div>

            <div class="display-flex" style="gap:10px; margin: 12px 16px;">
                <div class="es-summary-box es-summary-masuk">
                    <div class="font12 text-color-gray">Total Masuk</div>
                    <div class="font16 bold warna_tulisan_hijau" id="es-total-masuk">Rp 0</div>
                </div>
                <div class="es-summary-box es-summary-keluar">
                    <div class="font12 text-color-gray">Total Keluar</div>
                    <div class="font16 bold warna_tulisan_merah" id="es-total-keluar">Rp 0</div>
                </div>
            </div>

            <div class="aktivitas-section" style="margin: 0 16px 16px;">
                <div id="es-list-container">
                    <div class="text-align-center padding">
                        <span class="font13 text-color-gray">Memuat data...</span>
                    </div>
                </div>
            </div>

            <div class="padding-horizontal">
                <div id="es-btn-download-wrap"></div>
            </div>

        </div>
    </div>
</template>

<script>
    import jsPDF from 'jspdf';
    import { apiFetch, getUser } from '../js/config.js';

const LOGO_BASE64 = 'data:image/png;base64,';


    export default (props, { $f7, $on }) => {

        let transactions = [];
        let totalMasuk = 0;
        let totalKeluar = 0;
        let activePeriod = 'bulanan';

        function formatRp(n) {
            return 'Rp ' + Number(n || 0).toLocaleString('id-ID');
        }

        function toStr(d) {
            return d.toISOString().slice(0, 10);
        }

        // ── Bangun sub-input sesuai periode yang dipilih ──────────
        function buildSubInput(period) {
            const now = new Date();
            const subWrap = document.getElementById('es-sub-input');
            if (!subWrap) return;

            if (period === 'harian') {
                subWrap.innerHTML =
                    '<div class="es-tgl-label">Pilih Tanggal</div>' +
                    '<input type="date" id="es-inp-harian" class="es-select" value="' + toStr(now) + '">';

            } else if (period === 'mingguan') {
                // Senin minggu ini
                const day = now.getDay() === 0 ? 6 : now.getDay() - 1;
                const senin = new Date(now);
                senin.setDate(now.getDate() - day);
                const minggu = new Date(senin);
                minggu.setDate(senin.getDate() + 6);
                subWrap.innerHTML =
                    '<div class="es-tgl-label">Dari Tanggal</div>' +
                    '<input type="date" id="es-inp-minggu-dari" class="es-select" value="' + toStr(senin) + '">' +
                    '<div class="es-tgl-label" style="margin-top:8px;">Sampai Tanggal</div>' +
                    '<input type="date" id="es-inp-minggu-sampai" class="es-select" value="' + toStr(minggu) + '">';

            } else if (period === 'bulanan') {
                // Buat option bulan
                const namaBulan = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
                let optBulan = '';
                namaBulan.forEach(function(b, i) {
                    optBulan += '<option value="' + (i + 1) + '"' + (i === now.getMonth() ? ' selected' : '') + '>' + b + '</option>';
                });
                // Buat option tahun (5 tahun ke belakang)
                let optTahun = '';
                for (let y = now.getFullYear(); y >= now.getFullYear() - 5; y--) {
                    optTahun += '<option value="' + y + '">' + y + '</option>';
                }
                subWrap.innerHTML =
                    '<div class="display-flex" style="gap:8px;">' +
                        '<div style="flex:2;">' +
                            '<div class="es-tgl-label">Bulan</div>' +
                            '<select id="es-inp-bulan" class="es-select">' + optBulan + '</select>' +
                        '</div>' +
                        '<div style="flex:1;">' +
                            '<div class="es-tgl-label">Tahun</div>' +
                            '<select id="es-inp-tahun-bulan" class="es-select">' + optTahun + '</select>' +
                        '</div>' +
                    '</div>';

            } else if (period === 'tahunan') {
                let optTahun = '';
                for (let y = now.getFullYear(); y >= now.getFullYear() - 5; y--) {
                    optTahun += '<option value="' + y + '">' + y + '</option>';
                }
                subWrap.innerHTML =
                    '<div class="es-tgl-label">Pilih Tahun</div>' +
                    '<select id="es-inp-tahun" class="es-select">' + optTahun + '</select>';
            }
        }

        // ── Hitung from/to dari input yang aktif ─────────────────
        function getDateRange() {
            const now = new Date();
            if (activePeriod === 'harian') {
                const val = document.getElementById('es-inp-harian') ? document.getElementById('es-inp-harian').value : toStr(now);
                return { from: val, to: val };

            } else if (activePeriod === 'mingguan') {
                const dari = document.getElementById('es-inp-minggu-dari') ? document.getElementById('es-inp-minggu-dari').value : '';
                const sampai = document.getElementById('es-inp-minggu-sampai') ? document.getElementById('es-inp-minggu-sampai').value : '';
                return { from: dari, to: sampai };

            } else if (activePeriod === 'bulanan') {
                const bulan = document.getElementById('es-inp-bulan') ? parseInt(document.getElementById('es-inp-bulan').value) : now.getMonth() + 1;
                console.log('[ES] bulan selected:', bulan, 'now.getMonth():', now.getMonth());
                const tahun = document.getElementById('es-inp-tahun-bulan') ? parseInt(document.getElementById('es-inp-tahun-bulan').value) : now.getFullYear();
                const firstDay = new Date(tahun, bulan - 1, 1);
                const lastDay = new Date(tahun, bulan, 0);
                return { from: toStr(firstDay), to: toStr(lastDay) };

            } else if (activePeriod === 'tahunan') {
                const tahun = document.getElementById('es-inp-tahun') ? parseInt(document.getElementById('es-inp-tahun').value) : now.getFullYear();
                return { from: tahun + '-01-01', to: tahun + '-12-31' };
            }

            return { from: toStr(now), to: toStr(now) };
        }

        function buildFilterUI() {
            const filterWrap = document.getElementById('es-filter-wrap');
            if (!filterWrap) return;

            filterWrap.innerHTML =
                '<div class="es-tgl-label">Periode</div>' +
                '<div id="es-period-tabs" style="display:flex; gap:8px;">' +
                    '<button class="es-period-btn' + (activePeriod === 'harian' ? ' active' : '') + '" data-period="harian">Harian</button>' +
                    '<button class="es-period-btn' + (activePeriod === 'mingguan' ? ' active' : '') + '" data-period="mingguan">Mingguan</button>' +
                    '<button class="es-period-btn' + (activePeriod === 'bulanan' ? ' active' : '') + '" data-period="bulanan">Bulanan</button>' +
                    '<button class="es-period-btn' + (activePeriod === 'tahunan' ? ' active' : '') + '" data-period="tahunan">Tahunan</button>' +
                '</div>' +
                '<div id="es-sub-input" style="margin-top:10px;"></div>' +
                '<div class="es-tgl-label" style="margin-top:10px;">Jenis Transaksi</div>' +
                '<select id="es-type" class="es-select">' +
                    '<option value="">Semua Transaksi</option>' +
                    '<option value="topup">Top Up</option>' +
                    '<option value="transfer_in">Transfer Masuk</option>' +
                    '<option value="transfer_out">Transfer Keluar</option>' +
                '</select>' +
                '<button id="es-btn-filter" class="es-btn-filter" style="margin-top:14px; width:100%; border:none;">Terapkan Filter</button>';

            // Render sub-input sesuai periode aktif
            buildSubInput(activePeriod);

            // Event klik tombol periode
            document.getElementById('es-period-tabs').addEventListener('click', function(e) {
                const btn = e.target.closest('[data-period]');
                if (!btn) return;
                activePeriod = btn.getAttribute('data-period');
                document.querySelectorAll('.es-period-btn').forEach(function(b) {
                    b.classList.toggle('active', b.getAttribute('data-period') === activePeriod);
                });
                buildSubInput(activePeriod);
            });

            const btnWrap = document.getElementById('es-btn-download-wrap');
            if (btnWrap) {
                btnWrap.innerHTML =
                    '<button id="es-btn-download" class="es-btn-download" style="border:none;">' +
                        '<i class="icon f7-icons font18" style="margin-right:8px;">doc_text_fill</i>' +
                        'Unduh PDF' +
                    '</button>';
            }
        }

        function renderList() {
            const container = document.getElementById('es-list-container');
            if (!container) return;

            if (transactions.length === 0) {
                container.innerHTML =
                    '<div class="text-align-center padding">' +
                        '<i class="icon f7-icons font32 text-color-gray">tray</i>' +
                        '<p class="text-color-gray font13">Tidak ada transaksi pada periode ini</p>' +
                    '</div>';
                return;
            }

            const groups = {};
            transactions.forEach(function(item) {
                const dateKey = new Date(item.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
                if (!groups[dateKey]) groups[dateKey] = [];
                groups[dateKey].push(item);
            });

            let html = '';
            Object.keys(groups).forEach(function(dateKey) {
                html += '<div class="es-tgl-label">' + dateKey + '</div>';
                groups[dateKey].forEach(function(item) {
                    const icon = item.type === 'topup' ? 'plus_circle'
                        : item.type === 'transfer_in' ? 'arrow_down_circle'
                        : 'arrow_up_circle';
                    const wrapClass = item.type === 'topup' ? 'topup' : 'transfer';
                    const isMasuk = item.type !== 'transfer_out';
                    const color = isMasuk ? '#22c55e' : '#ef4444';
                    const prefix = isMasuk ? '+' : '-';
                    const nominal = item.amount ? prefix + formatRp(item.amount) : '';
                    const jam = new Date(item.created_at).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
                    const d = item.detail || {};
                    const saldoBefore = d.saldoBefore ? formatRp(d.saldoBefore) : null;
                    const saldoAfter = d.saldoAfter ? formatRp(d.saldoAfter) : null;
                    const pihakLain = item.type === 'topup'
                        ? (d.merchantName || '')
                        : item.type === 'transfer_in'
                        ? (d.senderName || '')
                        : (d.receiverName || '');

                    html +=
                        '<div class="trx-item" style="flex-direction:column;align-items:stretch;padding:12px 0;">' +
                            '<div style="display:flex;align-items:center;">' +
                                '<div class="trx-icon-wrap ' + wrapClass + '">' +
                                    '<i class="icon f7-icons font20" style="color:' + color + '">' + icon + '</i>' +
                                '</div>' +
                                '<div class="trx-info" style="flex:1;">' +
                                    '<div class="trx-nama">' + item.title + '</div>' +
                                    (pihakLain ? '<div style="font-size:11px;color:#9ca3af;">' + pihakLain + '</div>' : '') +
                                    '<div class="trx-tanggal">' + jam + '</div>' +
                                '</div>' +
                                '<div class="trx-nominal ' + (isMasuk ? 'masuk' : 'keluar') + '">' + nominal + '</div>' +
                            '</div>' +
                            (saldoBefore || saldoAfter ? 
                                '<div style="display:flex;justify-content:space-between;margin-top:8px;padding:6px 10px;background:#f9fafb;border-radius:6px;">' +
                                    (saldoBefore ? '<div style="font-size:11px;color:#9ca3af;">Saldo sebelum: <span style="color:#374151;font-weight:500;">' + saldoBefore + '</span></div>' : '') +
                                    (saldoAfter ? '<div style="font-size:11px;color:#9ca3af;">Saldo sesudah: <span style="color:#374151;font-weight:500;">' + saldoAfter + '</span></div>' : '') +
                                '</div>' : '') +
                        '</div>';
                });
            });

            container.innerHTML = html;
        }

        function hitungSummary() {
            totalMasuk = 0;
            totalKeluar = 0;
            transactions.forEach(function(item) {
                if (!item.amount) return;
                if (item.type === 'transfer_out') {
                    totalKeluar += parseFloat(item.amount);
                } else {
                    totalMasuk += parseFloat(item.amount);
                }
            });
            const elMasuk = document.getElementById('es-total-masuk');
            const elKeluar = document.getElementById('es-total-keluar');
            if (elMasuk) elMasuk.textContent = formatRp(totalMasuk);
            if (elKeluar) elKeluar.textContent = formatRp(totalKeluar);
        }

        async function loadStatement() {
            const container = document.getElementById('es-list-container');
            if (container) {
                container.innerHTML = '<div class="text-align-center padding"><span class="font13 text-color-gray">Memuat data...</span></div>';
            }

            const { from, to } = getDateRange();
            const type = document.getElementById('es-type') ? document.getElementById('es-type').value : '';

            let url = '/api/history';
            const params = ['date_from=' + from, 'date_to=' + to, 'exclude_type=system'];  // ← tambah ini
            if (type) params.push('type=' + encodeURIComponent(type));
            url += '?' + params.join('&');

            try {
                const data = await apiFetch(url);
                transactions = (data.success && data.data) ? data.data.filter(function(item) {
                    return item.type !== 'system';  // ← filter di frontend juga sebagai safety
                }) : [];
            } catch (err) {
                transactions = [];
                $f7.toast.create({ text: 'Gagal memuat data e-Statement', position: 'bottom', closeTimeout: 2000 }).open();
            }

            hitungSummary();
            renderList();
        }

        function downloadPDF() {
            if (transactions.length === 0) {
                $f7.toast.create({
                    text: 'Tidak ada data untuk diunduh',
                    position: 'bottom',
                    closeTimeout: 2000
                }).open();
                return;
            }

            generatePDF(LOGO_BASE64);
        }

        function formatTanggalPDF(date) {
            return new Date(date).toLocaleDateString('id-ID', {
                day: '2-digit',
                month: '2-digit',
                year: 'numeric'
            });
        }

        function formatJamPDF(date) {
            return new Date(date).toLocaleTimeString('id-ID', {
                hour: '2-digit',
                minute: '2-digit'
            });
        }

        function getSaldoAwalAkhir() {
            // Urutkan transaksi dari yang terlama
            const sorted = [...transactions].sort((a, b) => new Date(a.created_at) - new Date(b.created_at));
            
            let saldoAwal = null;
            let saldoAkhir = null;

            for (const item of sorted) {
                const d = item.detail || {};
                if (d.saldoBefore !== undefined && d.saldoBefore !== null && saldoAwal === null) {
                    saldoAwal = parseFloat(d.saldoBefore);
                }
                if (d.saldoAfter !== undefined && d.saldoAfter !== null) {
                    saldoAkhir = parseFloat(d.saldoAfter);
                }
            }

            return { saldoAwal, saldoAkhir };
        }

        function generatePDF(logoBase64) {

            const user = getUser() || {};
            const { from, to } = getDateRange();

            const doc = new jsPDF({
                orientation: 'portrait',
                unit: 'mm',
                format: 'a4'
            });

            const pageWidth = doc.internal.pageSize.getWidth();
            const pageHeight = doc.internal.pageSize.getHeight();

            const margin = 15;

            let y = 20;
            let page = 1;

            //---------------------------------------------------
            // WARNA
            //---------------------------------------------------

            const PRIMARY = [18, 93, 255];
            const SUCCESS = [34, 197, 94];
            const DANGER = [239, 68, 68];
            const GRAY = [120, 120, 120];
            const LIGHT = [245, 247, 250];
            const BORDER = [225, 229, 235];

            //---------------------------------------------------
            // WATERMARK
            //---------------------------------------------------

            function drawWatermark(){

                doc.saveGraphicsState();

                doc.setFontSize(42);
                doc.setTextColor(240);

                doc.text(
                    "DOGI PAY",
                    pageWidth/2,
                    pageHeight/2,
                    {
                        align:"center",
                        angle:35
                    }
                );

                doc.restoreGraphicsState();

            }
            //---------------------------------------------------
            // HEADER
            //---------------------------------------------------

            function drawHeader(){

                y = 18;

                if(logoBase64){

                    doc.addImage(
                        logoBase64,
                        "PNG",
                        pageWidth/2-10,
                        y,
                        20,
                        20
                    );

                }

                y += 27;

                doc.setFont("helvetica","bold");
                doc.setFontSize(20);
                doc.setTextColor(...PRIMARY);

                doc.text(
                    "DOGI PAY",
                    pageWidth/2,
                    y,
                    {align:"center"}
                );

                y += 6;

                doc.setFont("helvetica","normal");
                doc.setFontSize(10);
                doc.setTextColor(...GRAY);

                doc.text(
                    "Electronic Account Statement",
                    pageWidth/2,
                    y,
                    {align:"center"}
                );

                y += 7;

                doc.setDrawColor(...PRIMARY);
                doc.setLineWidth(.5);

                doc.line(
                    margin,
                    y,
                    pageWidth-margin,
                    y
                );

                y += 8;

            }
            //---------------------------------------------------
            // INFO NASABAH
            //---------------------------------------------------

            function drawCustomerCard(){

                doc.setFillColor(...LIGHT);
                doc.setDrawColor(...BORDER);

                doc.roundedRect(
                    margin,
                    y,
                    pageWidth-(margin*2),
                    36,
                    2,
                    2,
                    "FD"
                );

                let yy = y + 7;

                doc.setFontSize(10);

                doc.setFont("helvetica","bold");
                doc.setTextColor(80);

                doc.text("Informasi Pemilik Akun",margin+4,yy);

                yy += 6;

                doc.setFont("helvetica","normal");
                doc.setTextColor(40);

                doc.text("Nama",margin+4,yy);
                doc.text(":",margin+34,yy);
                doc.text(user.name || "-",margin+38,yy);

                yy += 6;

                doc.text("Nomor HP",margin+4,yy);
                doc.text(":",margin+34,yy);
                doc.text(user.phone || "-",margin+38,yy);

                yy += 6;

                doc.text("Periode",margin+4,yy);
                doc.text(":",margin+34,yy);
                doc.text(from+"  s/d  "+to,margin+38,yy);

                yy += 6;

                doc.text("Dicetak",margin+4,yy);
                doc.text(":",margin+34,yy);

                doc.text(
                    new Date().toLocaleString("id-ID"),
                    margin+38,
                    yy
                );

                y += 44;

            }
            //---------------------------------------------------
            // SUMMARY
            //---------------------------------------------------

            function drawSummaryCard() {
                const w = pageWidth - (margin * 2);
                const { saldoAwal, saldoAkhir } = getSaldoAwalAkhir();  // ← tambah ini

                doc.setFillColor(248, 249, 251);
                doc.roundedRect(margin, y, w, 42, 2, 2, 'F');  // ← tinggi dari 28 → 42

                doc.setFontSize(11);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(40);
                doc.text('Ringkasan Transaksi', pageWidth / 2, y + 7, { align: 'center' });

                doc.setFont('helvetica', 'normal');
                doc.setFontSize(10);

                // Saldo Awal
                doc.setTextColor(40);
                doc.text('Saldo Awal', margin + 5, y + 16);
                doc.setTextColor(...PRIMARY);
                doc.text(
                    saldoAwal !== null ? formatRp(saldoAwal) : '-',
                    pageWidth - margin - 5, y + 16, { align: 'right' }
                );

                // Total Masuk
                doc.setTextColor(40);
                doc.text('Total Masuk', margin + 5, y + 23);
                doc.setTextColor(...SUCCESS);
                doc.text(formatRp(totalMasuk), pageWidth - margin - 5, y + 23, { align: 'right' });

                // Total Keluar
                doc.setTextColor(40);
                doc.text('Total Keluar', margin + 5, y + 30);
                doc.setTextColor(...DANGER);
                doc.text(formatRp(totalKeluar), pageWidth - margin - 5, y + 30, { align: 'right' });

                // Saldo Akhir
                doc.setTextColor(40);
                doc.text('Saldo Akhir', margin + 5, y + 37);
                doc.setTextColor(...PRIMARY);
                doc.text(
                    saldoAkhir !== null ? formatRp(saldoAkhir) : '-',
                    pageWidth - margin - 5, y + 37, { align: 'right' }
                );

                doc.setTextColor(40);
                y += 56;  // ← dari 42 → 56
            }
            //---------------------------------------------------
            // HEADER TABEL
            //---------------------------------------------------

            function drawTableHeader(){

                doc.setFillColor(...PRIMARY);

                doc.rect(
                    margin,
                    y,
                    pageWidth-(margin*2),
                    8,
                    "F"
                );

                doc.setTextColor(255);

                doc.setFontSize(9);

                doc.setFont("helvetica","bold");

                doc.text(
                    "Tanggal",
                    margin + 3,
                    y + 5
                );

                doc.text(
                    "Keterangan",
                    52,
                    y + 5
                );

                doc.text(
                    "Nominal",
                    pageWidth - margin - 3,
                    y + 5,
                    {
                        align: "right"
                    }
                );

                y += 15;

            }
            //---------------------------------------------------
            // FOOTER
            //---------------------------------------------------

            function drawFooter() {

                const footerY = pageHeight - 12;

                doc.setDrawColor(...BORDER);
                doc.line(
                    margin,
                    footerY - 5,
                    pageWidth - margin,
                    footerY - 5
                );

                doc.setFont("helvetica", "normal");
                doc.setFontSize(8);
                doc.setTextColor(120);

                doc.text(
                    "Dokumen ini diterbitkan secara otomatis oleh DOGI PAY",
                    margin,
                    footerY
                );

                doc.text(
                    "Halaman " + page,
                    pageWidth - margin,
                    footerY,
                    { align: "right" }
                );

            }
            //---------------------------------------------------
            // ROW TRANSAKSI
            //---------------------------------------------------

            function drawTransaction(item) {
                if (y > 268) {
                    drawFooter();
                    nextPage();
                }

                const d = item.detail || {};
                const tanggal = formatTanggalPDF(item.created_at);
                const jam = formatJamPDF(item.created_at);
                const nominal = (item.type === 'transfer_out' ? '-' : '+') + formatRp(item.amount);

                const pihakLain = item.type === 'topup'
                    ? (d.merchantName ? ' - ' + d.merchantName : '')
                    : item.type === 'transfer_in'
                    ? (d.senderName ? ' dari ' + d.senderName : '')
                    : (d.receiverName ? ' ke ' + d.receiverName : '');

                const keteranganLengkap = (item.title || '-') + pihakLain;
                const deskripsi = doc.splitTextToSize(keteranganLengkap, 90);

                doc.setFontSize(9);
                doc.setFont('helvetica', 'normal');
                doc.setTextColor(60);

                // Tanggal + jam
                doc.text(tanggal, margin + 2, y);
                doc.setFontSize(8);
                doc.setTextColor(120);
                doc.text(jam, margin + 2, y + 4);

                // Keterangan
                doc.setFontSize(9);
                doc.setTextColor(60);
                doc.text(deskripsi, 52, y);

                // Saldo sebelum/sesudah
                if (d.saldoBefore !== undefined && d.saldoBefore !== null) {
                    doc.setFontSize(7.5);
                    doc.setTextColor(150);
                    doc.text('Saldo sebelum: ' + formatRp(d.saldoBefore), 52, y + (deskripsi.length * 4) + 1);
                    doc.text('Saldo sesudah: ' + formatRp(d.saldoAfter), 52, y + (deskripsi.length * 4) + 5);
                }

                // Nominal
                if (item.type === 'transfer_out') {
                    doc.setTextColor(...DANGER);
                } else {
                    doc.setTextColor(...SUCCESS);
                }
                doc.setFontSize(9);
                doc.setFont('helvetica', 'bold');
                doc.text(nominal, pageWidth - margin - 2, y, { align: 'right' });

                doc.setFont('helvetica', 'normal');
                doc.setTextColor(40);

                // Hitung tinggi row (lebih tinggi karena ada saldo sebelum/sesudah)
                const hasSaldo = d.saldoBefore !== undefined && d.saldoBefore !== null;
                const tinggi = Math.max(deskripsi.length * 4, 6) + (hasSaldo ? 10 : 0);
                y += tinggi;

                doc.setDrawColor(235);
                doc.line(margin, y, pageWidth - margin, y);
                y += 5;
            }

            //---------------------------------------------------
            // PAGE BREAK
            //---------------------------------------------------

            function nextPage(){

                doc.addPage();

                page++;

                drawWatermark();

                drawHeader();

                drawTableHeader();

            }
            drawWatermark();

            drawHeader();

            drawCustomerCard();

            drawSummaryCard();

            drawTableHeader();

            transactions.forEach(function(item){

                drawTransaction(item);

            });

            drawFooter();

            const pdfOutput = doc.output('arraybuffer');
            const fileName = 'e-statement-' + activePeriod + '-' + from + '.pdf';

            if (window.cordova && window.resolveLocalFileSystemURL) {
                // Mode Cordova (HP)
                const targetDir = cordova.file.externalRootDirectory + 'Download/';                
                window.resolveLocalFileSystemURL(targetDir, function(dirEntry) {
                    dirEntry.getFile(fileName, { create: true, exclusive: false }, function(fileEntry) {
                        fileEntry.createWriter(function(fileWriter) {
                            fileWriter.onwriteend = function() {
                                $f7.toast.create({ 
                                    text: 'PDF berhasil disimpan: ' + fileName, 
                                    position: 'bottom', 
                                    closeTimeout: 3000 
                                }).open();

                                // Buka PDF dengan app viewer
                                if (cordova.plugins && cordova.plugins.fileOpener2) {
                                    cordova.plugins.fileOpener2.open(
                                        fileEntry.nativeURL,
                                        'application/pdf',
                                        {
                                            error: function(e) {
                                                console.error('Error opening PDF:', e);
                                                $f7.dialog.alert('PDF tersimpan di: ' + fileEntry.nativeURL, 'PDF Tersimpan');
                                            },
                                            success: function() {
                                                console.log('PDF opened successfully');
                                            }
                                        }
                                    );
                                } else {
                                    $f7.dialog.alert('PDF tersimpan di folder Downloads aplikasi', 'PDF Tersimpan');
                                }
                            };
                            fileWriter.onerror = function(e) {
                                console.error('Write failed:', e);
                                $f7.toast.create({ text: 'Gagal menyimpan PDF', position: 'bottom', closeTimeout: 2000 }).open();
                            };
                            fileWriter.write(new Blob([pdfOutput], { type: 'application/pdf' }));
                        });
                    });
                }, function(err) {
                    console.error('resolveLocalFileSystemURL error:', err);
                    $f7.toast.create({ text: 'Gagal akses storage', position: 'bottom', closeTimeout: 2000 }).open();
                });

            } else {
                // Mode browser (fallback)
                doc.save(fileName);
            }

        }
        $on('pageAfterIn', () => {
            buildFilterUI();
            loadStatement();

            document.getElementById('es-btn-filter').addEventListener('click', loadStatement);
            document.getElementById('es-btn-download').addEventListener('click', downloadPDF);

            // ← Realtime: reload saat ada transaksi baru
            window._esReloadHandler = function() { loadStatement(); };
            window.addEventListener('dogipay-saldo-update', window._esReloadHandler);
            window.addEventListener('dogipay-transfer-sent', window._esReloadHandler);
            window.addEventListener('dogipay-transfer-received', window._esReloadHandler);
        });

        $on('pageBeforeRemove', () => {
            const btnFilter = document.getElementById('es-btn-filter');
            const btnDownload = document.getElementById('es-btn-download');
            if (btnFilter) btnFilter.removeEventListener('click', loadStatement);
            if (btnDownload) btnDownload.removeEventListener('click', downloadPDF);

            // ← Cleanup realtime listener
            if (window._esReloadHandler) {
                window.removeEventListener('dogipay-saldo-update', window._esReloadHandler);
                window.removeEventListener('dogipay-transfer-sent', window._esReloadHandler);
                window.removeEventListener('dogipay-transfer-received', window._esReloadHandler);
                window._esReloadHandler = null;
            }
        });

        return $render;
    }
</script>