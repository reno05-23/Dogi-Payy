{
  "name": "dogi-pay",
  "private": true,
  "version": "1.0.0",
  "description": "Dogi Pay",
  "repository": "",
  "license": "UNLICENSED",
  "scripts": {
    "start": "npm run dev",
    "dev": "cross-env NODE_ENV=development vite",
    "build": "cross-env NODE_ENV=production vite build",
    "build-cordova": "cross-env TARGET=cordova cross-env NODE_ENV=production vite build && node ./build/build-cordova.js && cd cordova && cordova build",
    "postinstall": "cpy --flat ./node_modules/framework7-icons/fonts/*.* ./src/fonts/ && cpy --flat ./node_modules/material-icons/iconfont/*.* ./src/fonts/"
  },
  "browserslist": [
    "IOS >= 15",
    "Safari >= 15",
    "last 5 Chrome versions",
    "last 5 Firefox versions"
  ],
  "dependencies": {
    "dom7": "^4.0.6",
    "framework7": "^9.0.5",
    "framework7-icons": "^5.0.5",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "material-icons": "^1.13.14",
    "qrcode-generator": "^2.0.4",
    "skeleton-elements": "^4.0.1",
    "swiper": "^12.2.0"
  },
  "devDependencies": {
    "cpy-cli": "^7.0.0",
    "cross-env": "^10.1.0",
    "less": "^4.6.7",
    "postcss-preset-env": "^11.3.1",
    "rollup": "^4.62.2",
    "rollup-plugin-framework7": "^1.2.1",
    "vite": "^8.1.0",
    "vite-plugin-html": "^3.2.2"
  }
}
